{
  "name": "mommydj-monorepo",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack -H 0.0.0.0",
    "dev:marketing": "npm -w apps/marketing run dev -- -p 3001",
    "build": "next build",
    "build:marketing": "npm -w apps/marketing run build",
    "build:all": "npm run build && npm run build:marketing",
    "start": "next start",
    "start:marketing": "npm -w apps/marketing run start -- -p 3001",
    "lint": "eslint . --max-warnings=0 --no-warn-ignored --ignore-pattern 'backups/**'",
    "lint:fix": "eslint . --max-warnings=0 --no-warn-ignored --fix --ignore-pattern 'backups/**'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:smoke": "bash scripts/smoke-test-production.sh",
    "type-check": "tsc --noEmit",
    "ci": "npm run lint && npm run type-check && npm run test && npm run build",
    "health": "node scripts/check_health.js",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push scripts/check-large-files.sh",
    "hooks:check-large-files": "bash scripts/check-large-files.sh --staged",
    "clean": "rm -rf .next node_modules/.cache apps/marketing/.next apps/marketing/node_modules",
    "update-deps": "npm update && npm audit fix"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "next": "^16.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "supertest": "^7.1.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=9.8.0"
  }
}
